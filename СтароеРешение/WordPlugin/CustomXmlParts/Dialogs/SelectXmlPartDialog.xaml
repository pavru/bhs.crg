<Window x:Class="BHS.CustomXmlParts.Dialogs.SelectXmlPartDialog"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006" 
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008" 
             xmlns:local="clr-namespace:BHS.CustomXmlParts.Dialogs"
             mc:Ignorable="d" d:DesignWidth="386.156"
             Height="277" Width="386.156"
             Title="Select namespce to remove">
    <Grid Margin="5,5,5,5">
        <Grid.RowDefinitions>
            <RowDefinition Height="110*"/>
            <RowDefinition Height="141*"/>
        </Grid.RowDefinitions>
        <ListBox x:Name="NameSpaceList" d:ItemsSource="{d:SampleData ItemCount=5}" Margin="10,10,10,40" Grid.RowSpan="2"/>
        <Button x:Name="CancelButton" Content="Cancel" Margin="0,0,10,7" Click="CancelButton_Click" Grid.Row="1" HorizontalAlignment="Right" Width="55" Height="20" VerticalAlignment="Bottom" />
        <Button x:Name="RemoveButton" Content="Remove" Margin="0,0,83,7" RenderTransformOrigin="0.278,-0.319" Click="RemoveButton_Click" Grid.Row="1" HorizontalAlignment="Right" Width="59" Height="20" VerticalAlignment="Bottom" />

    </Grid>
</Window>

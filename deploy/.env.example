# ── Скопируйте в .env и заполните значения ──────────────────────────────────────
# cp deploy/.env.example deploy/.env

# PostgreSQL
POSTGRES_DB=bhs_crg
POSTGRES_USER=postgres
POSTGRES_PASSWORD=change_me_strong_password

# MinIO (объектное хранилище)
MINIO_ROOT_USER=minioadmin
MINIO_ROOT_PASSWORD=change_me_minio_password
MINIO_BUCKET=bhs-crg
MINIO_CONSOLE_PORT=9001

# JWT — длинный случайный секрет (минимум 32 символа!)
# Сгенерировать:  openssl rand -base64 48
JWT_KEY=CHANGE_ME_TO_A_LONG_RANDOM_SECRET_AT_LEAST_32_CHARS

# Веб-интерфейс (порт на хосте)
WEB_PORT=8080

# Публичный адрес системы (напр. https://docs.example.ru) — внешний URL, по которому
# пользователи открывают систему. Подставляется ссылкой в письма: сброс пароля,
# подтверждение/смена email, отправка крупного комплекта (> 15 МБ).
# ВАЖНО: без него письма со ссылками НЕ отправляются (действие вернёт понятную ошибку).
# Обязателен, если пользуетесь самостоятельным сбросом пароля / подтверждением почты.
APP_PUBLIC_URL=

# Ollama — локальная модель распознавания сканов (опционально, тяжёлая ~6 ГБ)
OLLAMA_MODEL=qwen2.5vl:7b

# Внешние сервисы (опционально; нужны только для документов качества)
# Anthropic / Gemini — распознавание реквизитов; Serper — веб-поиск документов
ANTHROPIC_API_KEY=
GEMINI_API_KEY=
SERPER_API_KEY=
